#include "MyAllocator.h"
#include "MyContainer.h"
#include <map>
#include <algorithm>
#include <iostream>

template<typename T1, typename T2, typename C, typename A>
void print_out(const std::map<T1, T2, C, A> & m)
{
	for (const auto& pair : m)
		std::cout << pair.first <<"\t" << pair.second<<  std::endl;
}
template <typename T, typename A>
void print_out( MyContainer<T, A> &cont)
{
	for (auto it:cont)
		std::cout << it << "\n";
}

int main()
{
	//создание MyAllocator 
	//auto alloc = make_block_allocator<std::pair<const int, int>>(10);
	
	// Для std::map
	std::map<int, int, std::less<int>, MyAllocator<std::pair<const int, int>, 10>> myMap;


	std::map<int, int, std::less<int>, MyAllocator<std::pair<const int, int>, 10>> m;

	//запоняем контейнеры
	for (int iii =0; iii < 10; iii++)
	{
		if ( (iii==0) || (iii == 1))
		{
			myMap[iii] = 1;
			m[iii] = 1;
			continue;
		}
		myMap[iii] = myMap[iii-1] * iii;
		m[iii] = m[iii-1] * iii;
	}
	printf("Выводим контейнер myMap с аллокатором, в качетсве шаблонного параметра передано кол-во элементов\n");
	print_out(myMap);

	// Для своего контейнера	
	
	MyContainer <int, MyAllocator<int, 10> > customContainer;
	
	std::cout << "Первый контейнер Создался" <<std::endl;	
	for (int iii=0; iii<10; ++iii){
		customContainer.push_back(iii);
	}
	std::cout << "Выводим свой контейнер с custom аллокатором" <<"\n";
	print_out(customContainer);

	MyContainer <int > justContainer;
	for(int i =0; i<10; i++){
		justContainer.push_back(i);
	}
	std::cout << "Выводим свой контейнер с std::аллокатором" <<"\n";
	print_out(justContainer);
	return 0;
}
